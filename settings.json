{
  "theme": "dark",
  "packages": [
    "npm:pi-guard"
  ],
  "guard": {
    "rules": {
      "bash": {
        "*": "ask",
        "find": "allow",
        "fd": "allow",
        "ls": "allow",
        "grep": "allow",
        "rg": "allow",
        "git status": "allow",
        "git diff": "allow",
        "uv run pytest": "allow",
        "uv run pre-commit": "allow",
        "pre-commit": "allow",
        "rm": "deny",
        "git merge": "deny",
        "git revert": "deny",
        "git reset": "deny",
        "git rebase": "deny",
        "uv tool": "deny"
      },
      "read": {
        "*": "allow",
        "**/.env*": "deny",
        "**/*secret*": "deny",
        "**/*password*": "deny",
        "**/*token*": "deny",
        "**/secrets/**": "deny",
        "**/credentials/**": "deny",
        "**/*.pem": "deny",
        "**/*.key": "deny",
        "**/*.crt": "deny",
        "**/*.p12": "deny"
      },
      "write": {
        "*": "ask"
      },
      "edit": {
        "*": "ask"
      }
    }
  }
}
